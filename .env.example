# Ingestion
LAUNCH_LIBRARY_BASE_URL=https://ll.thespacedevs.com/2.2.0/launch/
SPACEX_ROCKETS_URL=https://api.spacexdata.com/v4/rockets
SPACEX_LAUNCHES_QUERY_URL=https://api.spacexdata.com/v5/launches/query
SPACEX_LAUNCHPADS_URL=https://api.spacexdata.com/v4/launchpads
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive
LAUNCH_LIBRARY_LIMIT=100
LAUNCH_LIBRARY_MAX_PAGES=5
LAUNCH_LIBRARY_BATCH_MODE=1
LAUNCH_LIBRARY_RESET_CURSOR=0
LAUNCH_LIBRARY_SYNTHETIC_MODE=1
LAUNCH_LIBRARY_SYNTHETIC_TARGET=1000
LAUNCH_LIBRARY_CURSOR_FILE=/app/data/raw/.launch_library_cursor.json
SPACEX_LAUNCHES_PAGE_SIZE=100
SPACEX_LAUNCHES_MAX_PAGES=200
SPACEX_PAYLOADS_URL=https://api.spacexdata.com/v4/payloads
SPACEX_CORES_URL=https://api.spacexdata.com/v4/cores
SPACEX_SHIPS_URL=https://api.spacexdata.com/v4/ships
WEATHER_MAX_REQUESTS=500
REQUEST_TIMEOUT_SECONDS=30

# PostgreSQL
POSTGRES_USER=space_user
POSTGRES_PASSWORD=space_pass
POSTGRES_DB=space_launches
